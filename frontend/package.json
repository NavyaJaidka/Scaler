{
  "name": "ai-persona-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/stable-dev.cjs",
    "dev:watch": "node scripts/dev-server.cjs",
    "dev:turbo": "node scripts/dev-server.cjs --turbo",
    "dev:clean": "node scripts/stable-dev.cjs",
    "dev:stop": "node scripts/stop-dev.cjs",
    "clean": "node scripts/clean-next.cjs",
    "build": "node scripts/clean-next.cjs && node scripts/next-run.cjs build",
